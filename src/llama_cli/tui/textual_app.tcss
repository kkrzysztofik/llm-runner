$footer-key-background: ansi_bright_yellow;
$footer-key-foreground: black;
$footer-description-foreground: ansi_bright_white;
$footer-description-background: transparent;

Screen {
    layout: vertical;
    background: black;
    color: ansi_bright_white;
}

#dashboard {
    height: 1fr;
    layout: vertical;
    background: black;
}

#content {
    height: 1fr;
    layout: horizontal;
    background: black;
}

.hidden {
    display: none;
}
