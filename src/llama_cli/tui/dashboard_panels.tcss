.column,
.server-log-panel {
    width: 1fr;
    height: 1fr;
}

.server-log-panel {
    border: round ansi_bright_blue;
    padding: 0 1;
    layout: vertical;
    background: black;
    color: ansi_bright_white;
}

.server-column {
    width: 1fr;
    height: 1fr;
    layout: vertical;
}

.server-column-header {
    height: auto;
    margin-bottom: 1;
}

.server-column-title-row,
.server-column-meta-row,
.server-column-url-row {
    height: 1;
    layout: horizontal;
}

.server-column-profile-name {
    width: 1fr;
    color: $accent;
    text-style: bold;
}

.server-column-status {
    width: auto;
    margin-left: 1;
    padding: 0 1;
    text-style: bold;
}

.server-column-backend {
    width: auto;
    margin-right: 1;
    color: ansi_bright_cyan;
    text-style: bold;
}

.server-column-config {
    width: 1fr;
    color: ansi_bright_cyan;
}

.server-column-url-label {
    width: auto;
    margin-right: 1;
    color: ansi_bright_black;
    text-style: bold;
}

.server-column-url {
    width: 1fr;
    color: ansi_white;
}

.server-column-status-running {
    color: ansi_bright_green;
}

.server-column-status-launching,
.server-column-status-degraded {
    color: ansi_bright_yellow;
}

.server-column-status-crashed {
    color: ansi_bright_red;
}

.server-column-status-offline,
.server-column-status-idle {
    color: ansi_bright_black;
}

.server-column-backend,
.server-column-config {
    color: ansi_bright_cyan;
}

.server-column-url {
    color: ansi_white;
}

.server-column-warning {
    color: ansi_bright_yellow;
}

.slot-stats {
    height: auto;
    border: round ansi_bright_black;
    padding: 0 1;
    margin-bottom: 1;
    layout: vertical;
    background: black;
}

.slot-stats-title {
    width: auto;
    text-style: bold;
}

.slot-stats-row {
    height: 2;
    layout: horizontal;
}

.slot-stats-cell {
    width: 1fr;
    height: 2;
    layout: vertical;
}

.slot-stats-label {
    height: 1;
    color: ansi_bright_black;
}

.slot-stats-value {
    height: 1;
    color: ansi_bright_white;
    text-style: bold;
}

.gpu-stats,
.server-logs,
.server-placeholder {
    height: auto;
    border: round ansi_bright_black;
    padding: 0 1;
    margin-bottom: 1;
    layout: vertical;
    background: black;
    color: ansi_bright_white;
}

.gpu-stats-title,
.server-log-title,
.server-placeholder-title {
    width: auto;
    text-style: bold;
}

.gpu-stats-row,
.gpu-stats-usage-row {
    height: 1;
    layout: horizontal;
}

.gpu-stats-label,
.gpu-stats-usage-label {
    width: auto;
    margin-right: 1;
    color: ansi_bright_cyan;
}

.gpu-stats-value {
    width: auto;
    margin-right: 2;
    color: ansi_bright_white;
}

.gpu-stats-muted-value,
.gpu-stats-unavailable,
.server-placeholder-body {
    color: ansi_bright_black;
}

.gpu-stats-usage-item {
    width: 1fr;
    height: 1;
    layout: horizontal;
}

.gpu-stats-usage-bar {
    width: auto;
    min-width: 10;
    margin-right: 1;
}

.gpu-stats-usage-low {
    color: ansi_bright_green;
}

.gpu-stats-usage-medium {
    color: ansi_bright_yellow;
}

.gpu-stats-usage-high {
    color: ansi_bright_red;
}

.gpu-stats-usage-unknown {
    color: ansi_bright_black;
}

.server-logs {
    height: 1fr;
}

.server-log-content {
    height: 1fr;
    color: ansi_bright_white;
    overflow-y: auto;
}

