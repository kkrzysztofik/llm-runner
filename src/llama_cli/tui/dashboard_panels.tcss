.column,
.server-log-panel {
    width: 1fr;
    height: 1fr;
}

.server-log-panel {
    border: round $panel;
    padding: 0 1;
    layout: vertical;
}

.server-column {
    height: 1fr;
    layout: vertical;
}

.server-column-header {
    height: auto;
    margin-bottom: 1;
}

.server-column-header-row {
    height: auto;
    layout: horizontal;
}

.server-column-alias {
    width: auto;
    margin-right: 1;
    color: $accent;
    text-style: bold;
}

.server-column-unsaved {
    width: auto;
    margin-right: 1;
    color: yellow;
    text-style: bold;
}

.server-column-status,
.server-column-backend,
.server-column-url {
    width: auto;
    margin-right: 1;
}

.server-column-status-running {
    color: green;
}

.server-column-status-launching,
.server-column-status-degraded {
    color: yellow;
}

.server-column-status-crashed {
    color: red;
}

.server-column-status-offline,
.server-column-status-idle {
    color: dim;
}

.server-column-backend,
.server-column-config {
    color: cyan;
}

.server-column-url {
    color: dim;
}

.server-column-warning {
    color: yellow;
}

.gpu-stats,
.server-logs,
.server-placeholder {
    height: auto;
    border: round $surface;
    padding: 0 1;
    margin-bottom: 1;
    layout: vertical;
}

.gpu-stats-title,
.server-log-title,
.server-placeholder-title {
    width: auto;
    text-style: bold;
}

.gpu-stats-row,
.gpu-stats-usage-row {
    height: auto;
    layout: horizontal;
}

.gpu-stats-label,
.gpu-stats-usage-label {
    width: auto;
    margin-right: 1;
    color: bright_cyan;
}

.gpu-stats-value {
    width: auto;
    margin-right: 2;
    color: bright_white;
}

.gpu-stats-muted-value,
.gpu-stats-unavailable,
.server-placeholder-body {
    color: dim;
}

.gpu-stats-usage-item {
    width: 1fr;
    height: auto;
    layout: horizontal;
}

.gpu-stats-usage-bar {
    width: auto;
    min-width: 10;
    margin-right: 1;
}

.gpu-stats-usage-low {
    color: green;
}

.gpu-stats-usage-medium {
    color: yellow;
}

.gpu-stats-usage-high {
    color: red;
}

.gpu-stats-usage-unknown {
    color: dim;
}

.server-logs {
    height: 1fr;
}

.server-log-content {
    height: 1fr;
    color: $text;
    overflow-y: auto;
}

.command-menu {
    layout: horizontal;
    height: 1;
}

.command-menu-item {
    width: auto;
    height: 1;
}

.command-menu-key {
    width: auto;
    min-width: 3;
    padding: 0 1;
    background: $accent;
    color: $text;
    text-style: bold;
}

.command-menu-description {
    width: auto;
    padding: 0 1;
}